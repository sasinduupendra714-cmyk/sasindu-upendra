{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user statistics, streak, and badges.",
      "type": "object",
      "properties": {
        "points": { "type": "number", "description": "Total points earned." },
        "streak": { "type": "number", "description": "Current study streak in days." },
        "lastStudyDate": { "type": "string", "format": "date", "description": "The last date the user studied." },
        "badges": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "icon": { "type": "string" },
              "unlockedAt": { "type": "string", "format": "date-time" },
              "type": { "type": "string", "enum": ["mastery", "streak", "sessions", "time"] },
              "requirement": { "type": "number" }
            }
          }
        },
        "totalSessions": { "type": "number", "description": "Total number of study sessions completed." },
        "totalStudyTime": { "type": "number", "description": "Total time spent studying in minutes." }
      },
      "required": ["points", "streak", "badges", "totalSessions", "totalStudyTime"]
    },
    "Subject": {
      "title": "Subject",
      "description": "Represents a study subject with topics and performance metrics.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "score": { "type": "number" },
        "focus": { "type": "number" },
        "weakCount": { "type": "number" },
        "status": { "type": "string", "enum": ["Critical", "Weak", "Strong"] },
        "priorityScore": { "type": "number" },
        "readiness": { "type": "number" },
        "gradient": { "type": "string" },
        "image": { "type": "string" },
        "topics": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "mastery": { "type": "number" },
              "image": { "type": "string" },
              "resources": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "title": { "type": "string" },
                    "url": { "type": "string" },
                    "type": { "type": "string", "enum": ["link", "video", "pdf", "other"] }
                  }
                }
              }
            }
          }
        }
      },
      "required": ["id", "name", "score", "focus", "weakCount", "status", "priorityScore", "readiness", "gradient", "topics"]
    },
    "StudyLog": {
      "title": "Study Log",
      "description": "Records a single study session.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "subjectId": { "type": "string" },
        "topicId": { "type": "string" },
        "duration": { "type": "number" },
        "focusLevel": { "type": "number" },
        "notes": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "subjectId", "topicId", "duration", "focusLevel", "notes", "timestamp"]
    },
    "WeeklySchedule": {
      "title": "Weekly Schedule",
      "description": "Stores the user's weekly study schedule.",
      "type": "object",
      "properties": {
        "Monday": { "type": "array", "items": { "$ref": "Activity" } },
        "Tuesday": { "type": "array", "items": { "$ref": "Activity" } },
        "Wednesday": { "type": "array", "items": { "$ref": "Activity" } },
        "Thursday": { "type": "array", "items": { "$ref": "Activity" } },
        "Friday": { "type": "array", "items": { "$ref": "Activity" } },
        "Saturday": { "type": "array", "items": { "$ref": "Activity" } },
        "Sunday": { "type": "array", "items": { "$ref": "Activity" } }
      }
    },
    "Activity": {
      "title": "Activity",
      "description": "A single scheduled activity.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "time": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["study", "tuition", "break", "rest"] }
      },
      "required": ["id", "time", "description", "type"]
    },
    "AIRecommendation": {
      "title": "AI Recommendation",
      "description": "A recommendation generated by AI.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "priority": { "type": "string", "enum": ["High", "Medium", "Low"] },
        "reason": { "type": "string" },
        "liked": { "type": "boolean" },
        "dismissed": { "type": "boolean" }
      },
      "required": ["id", "title", "description", "priority", "reason"]
    },
    "ExamRecord": {
      "title": "Exam Record",
      "description": "Stores results of an exam.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "marks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "subjectId": { "type": "string" },
              "score": { "type": "number" }
            }
          }
        },
        "totalScore": { "type": "number" },
        "averageScore": { "type": "number" },
        "rank": { "type": "number" },
        "notes": { "type": "string" }
      },
      "required": ["id", "title", "date", "marks", "totalScore", "averageScore"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User's profile and stats."
    },
    "/users/{userId}/subjects/{subjectId}": {
      "schema": "Subject",
      "description": "User's subjects."
    },
    "/users/{userId}/study_logs/{logId}": {
      "schema": "StudyLog",
      "description": "User's study session logs."
    },
    "/users/{userId}/schedules/weekly": {
      "schema": "WeeklySchedule",
      "description": "User's weekly schedule."
    },
    "/users/{userId}/recommendations/{recId}": {
      "schema": "AIRecommendation",
      "description": "User's AI recommendations."
    },
    "/users/{userId}/exams/{examId}": {
      "schema": "ExamRecord",
      "description": "User's exam records."
    }
  }
}
